################################################################################
project:
  name: "MagicSquare"
  language: "Python"
  description: ""
  goals:
    - "Magic Square 문제를 TDD로 해결"
    - "ECB(boundary/control/entity) 아키텍처 준수"
  constraints:
    - "Python 3.14+"
    - "PEP8 엄격 준수"
    - "Type hints 필수"
    - "pytest + AAA 패턴"
    - "Dual-Track TDD"
    - "print() 디버깅 금지"
    - "테스트 약화 금지"
    - "RED 없이 구현 금지"

################################################################################
code_style:
  python_version: "3.14+"
  style_guide: "PEP8 엄격 준수"
  type_hints: "모든 함수 파라미터와 반환값에 필수"
  docstring: "Google 스타일, 모든 public 메서드에 필수"
  max_line_length: 88

################################################################################
architecture:
  pattern: "ECB (boundary/control/entity)"
  layers:
    boundary: "외부 입출력 담당 (UI, API, CLI)"
    control: "비즈니스 로직 담당"
    entity: "도메인 데이터 및 규칙 담당"
  dependency_direction:
    allowed:
      - "boundary -> control"
      - "control -> entity"
    forbidden:
      - "entity -> control"
      - "entity -> boundary"
      - "control -> boundary"
  rules:
    - "I/O(입출력)는 boundary에서만 처리"
    - "entity는 순수 도메인 규칙/데이터에 집중 (프레임워크/입출력 의존 금지)"
    - "control은 유스케이스/흐름 제어, entity 조합 및 boundary 호출 결과를 오케스트레이션"

################################################################################
tdd_rules:
  red_phase:
    description: "테스트를 먼저 작성하고, 실패(RED)를 확인한 뒤에만 구현으로 진행한다."
    rules:
      - "새 기능/버그 수정은 테스트부터 작성"
      - "작성한 테스트가 의도한 이유로 실패하는지 확인"
      - "실패 메시지/조건이 명확하도록 최소한의 assertion으로 시작"
    must_not:
      - "테스트가 실패하는 것을 확인하기 전에 구현 코드 작성/수정"
      - "불명확한 실패(환경/설정 문제) 상태에서 구현으로 진행"
  green_phase:
    description: "테스트를 통과시키는 최소한의 코드만 작성한다. 이 단계에서는 리팩터링을 하지 않는다."
    rules:
      - "가장 단순한(최소) 구현으로 테스트 통과"
      - "중복/구조 개선은 다음 단계(refactor_phase)로 미룬다"
    must_not:
      - "구조 개선, 네이밍 정리, 모듈 분리 등 리팩터링"
      - "추가 기능/스펙 확장(테스트가 요구하지 않는 코드 추가)"
  refactor_phase:
    description: "기능 변경 없이 구조를 개선한다. 테스트 신뢰도와 커버리지를 유지한다."
    rules:
      - "동작(기능) 변경 없이 내부 구조 개선"
      - "테스트는 계속 통과해야 하며, 기존 커버리지 기준을 유지"
      - "중복 제거, 책임 분리, ECB 경계 정리"
    must_not:
      - "테스트 삭제/완화/skip으로 통과시키기"
      - "기능을 바꾸는 리팩터링(출력/규칙/예외/계산 결과 변경)"

################################################################################
testing:
  framework: "pytest"
  pattern: "AAA (Arrange-Act-Assert)"
  coverage_minimum: "80%"
  fixture_scope:
    rules:
      - "기본은 function scope 사용"
      - "session/module scope는 비용/성능 이슈가 명확할 때만 사용"
      - "fixture는 Arrange 단계 준비에만 사용하고, Assert 로직을 넣지 않는다"
  naming_convention:
    - "테스트 함수/메서드명은 test_ 접두사 필수"
    - "테스트 파일명은 test_*.py 규칙 준수"

################################################################################
forbidden:
  - pattern: "print(...)"
    reason: "디버깅 출력은 테스트 재현성과 로그 품질을 해치고, 제출/CI 환경에서 노이즈를 만든다."
    alternative: "pytest assertion/로그(필요 시 logging) 또는 디버거 사용"
  - pattern: "하드코딩 상수(매직 넘버/매직 문자열)를 로직에 직접 사용"
    reason: "의미가 불명확하고 변경에 취약하며, 테스트/도메인 규칙 추적이 어려워진다."
    alternative: "entity에 도메인 상수로 선언하거나, 명명된 상수/Enum/설정 값으로 추출"
  - pattern: "except:"
    reason: "SystemExit/KeyboardInterrupt 등까지 삼켜서 오류를 숨기고 테스트 신뢰도를 떨어뜨린다."
    alternative: "구체 예외(ExceptionType)로 처리하거나, 필요한 경우 'except Exception as e'로 제한"

################################################################################
file_structure:
  # .
  # ├─ src/
  # │  ├─ boundary/
  # │  │  ├─ cli/
  # │  │  └─ __init__.py
  # │  ├─ control/
  # │  │  └─ __init__.py
  # │  ├─ entity/
  # │  │  └─ __init__.py
  # │  └─ __init__.py
  # ├─ tests/
  # │  ├─ boundary/
  # │  ├─ control/
  # │  ├─ entity/
  # │  └─ __init__.py
  # ├─ pyproject.toml
  # └─ README.md
  note: "ECB 기준 폴더 트리는 위 주석 참조"

################################################################################
ai_behavior:
  before_coding:
    - "관련 테스트 파일(tests/**)을 먼저 확인하고, 없으면 RED 테스트부터 작성한다."
    - "ECB 레이어 경계(boundary/control/entity) 위반 가능성이 있으면 설계/배치를 먼저 조정한다."
    - "타입힌트 없는 함수/메서드는 생성하지 않는다."
  during_coding:
    - "tdd_rules를 준수한다: RED 확인 없이 구현을 진행하지 않는다."
    - "GREEN 단계에서는 최소 코드만 작성하고 리팩터링을 하지 않는다."
    - "ECB 의존성 방향을 지킨다 (boundary -> control -> entity)."
  after_coding:
    - "테스트 약화(삭제/완화/skip/의미 없는 assertion) 없이 모든 테스트가 통과하는지 확인한다."
    - "커버리지 최소 기준(80%)을 유지하도록 테스트를 보강한다."
    - "tdd_rules 또는 ECB 경계 위반이 감지되면, 채팅 응답에서 명확히 경고하고(원인/영향/대안) 진행을 멈춘다."
